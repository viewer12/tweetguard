# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Editors / IDEs
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath

# Node (in case future tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Build output (in case future tooling)
dist/
build/
out/

# 例外:marketing/out 是上架商店用的 PNG 成品,直接克隆仓库就能用,不需要每次重渲染
!marketing/out/
!marketing/out/**

# Logs
*.log
logs/

# Local environment / overrides (defense-in-depth: never accidentally commit secrets)
.env
.env.local
.env.*.local

# Personal config dumps (just in case any of these ever exist)
config.local.json
user.config.json
*.private.json

# OS thumbnails
Thumbs.db
ehthumbs.db
Desktop.ini
